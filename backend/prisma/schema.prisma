generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  fm
  super_admin
}

enum TicketStatus {
  open
  in_progress
  closed
}

enum ActivityType {
  created
  status_changed
  comment_added
  note_added
  attachment_added
  closed
}

model Category {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  tickets Ticket[]

  @@map("categories")
}

model Building {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(255)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  floors    Floor[]
  companies Company[]
  tickets   Ticket[]

  @@map("buildings")
}

model Floor {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  building_id String   @db.Uuid
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  building Building @relation(fields: [building_id], references: [id], onDelete: Cascade)
  tickets  Ticket[]

  @@map("floors")
}

model Company {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  building_id String?  @db.Uuid
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  building Building? @relation(fields: [building_id], references: [id], onDelete: SetNull)
  tickets  Ticket[]

  @@map("companies")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password_hash String
  role          Role      @default(fm)
  is_active     Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz

  tickets     Ticket[]
  activities  TicketActivity[]
  attachments Attachment[]

  @@map("users")
}

model Ticket {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_number String         @unique @db.VarChar(20)
  building_id   String         @db.Uuid
  floor_id      String         @db.Uuid
  company_id    String         @db.Uuid
  category_id   String         @db.Uuid
  sub_category  String?        @db.VarChar(255)
  description   String
  status        TicketStatus   @default(open)
  raised_by     String         @db.Uuid
  closed_at     DateTime?      @db.Timestamptz
  created_at    DateTime       @default(now()) @db.Timestamptz
  updated_at    DateTime       @updatedAt @db.Timestamptz

  building    Building         @relation(fields: [building_id], references: [id])
  floor       Floor            @relation(fields: [floor_id], references: [id])
  company     Company          @relation(fields: [company_id], references: [id])
  category    Category         @relation(fields: [category_id], references: [id])
  raiser      User             @relation(fields: [raised_by], references: [id])
  activities  TicketActivity[]
  attachments Attachment[]

  @@map("tickets")
}

model TicketActivity {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id     String       @db.Uuid
  actor_id      String       @db.Uuid
  activity_type ActivityType
  old_value     String?
  new_value     String?
  comment       String?
  is_internal   Boolean      @default(false)
  created_at    DateTime     @default(now()) @db.Timestamptz

  ticket Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actor_id], references: [id])

  @@map("ticket_activities")
}

model Attachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id   String   @db.Uuid
  uploaded_by String   @db.Uuid
  file_name   String?  @db.VarChar(255)
  file_url    String?
  file_size   Int?
  mime_type   String?  @db.VarChar(100)
  created_at  DateTime @default(now()) @db.Timestamptz

  ticket   Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploaded_by], references: [id])

  @@map("attachments")
}
