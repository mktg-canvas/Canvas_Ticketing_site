generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  cem
  super_admin
}

enum TicketStatus {
  open
  in_progress
  closed
}

enum TicketSource {
  client
  cem
}

enum ActivityType {
  created
  status_changed
  comment_added
  note_added
  attachment_added
  attachment_deleted
  closed
}

model Category {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(100)
  slug       String   @unique @db.VarChar(100)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  tickets Ticket[]

  @@map("categories")
}

model Building {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(255)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  floors    Floor[]
  tickets   Ticket[]
  locations ClientLocation[]

  @@map("buildings")
}

model Floor {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String   @db.VarChar(255)
  building_id String   @db.Uuid
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz
  updated_at  DateTime @updatedAt @db.Timestamptz

  building  Building          @relation(fields: [building_id], references: [id], onDelete: Cascade)
  tickets   Ticket[]
  locations ClientLocation[]

  @@map("floors")
}

model Client {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String   @db.VarChar(255)
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  tickets   Ticket[]
  locations ClientLocation[]

  @@map("clients")
}

model ClientLocation {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  client_id   String   @db.Uuid
  building_id String   @db.Uuid
  floor_id    String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz

  client   Client   @relation(fields: [client_id], references: [id], onDelete: Cascade)
  building Building @relation(fields: [building_id], references: [id], onDelete: Cascade)
  floor    Floor    @relation(fields: [floor_id], references: [id], onDelete: Cascade)

  @@unique([client_id, building_id, floor_id])
  @@map("client_locations")
}

model User {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name          String    @db.VarChar(255)
  email         String    @unique @db.VarChar(255)
  password_hash String
  role          Role      @default(cem)
  is_active     Boolean   @default(true)
  last_login    DateTime? @db.Timestamptz
  created_at    DateTime  @default(now()) @db.Timestamptz
  updated_at    DateTime  @updatedAt @db.Timestamptz

  tickets     Ticket[]
  activities  TicketActivity[]
  attachments Attachment[]

  @@map("users")
}

model Ticket {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_number Int            @unique @default(autoincrement())
  building_id   String         @db.Uuid
  floor_id      String         @db.Uuid
  client_id     String         @db.Uuid
  category_id   String         @db.Uuid
  sub_category  String?        @db.VarChar(255)
  description   String
  status        TicketStatus   @default(open)
  source        TicketSource   @default(client)
  raised_by     String         @db.Uuid
  is_priority      Boolean        @default(false)
  open_note        String?
  in_progress_note String?
  closed_note      String?
  opened_at     DateTime?      @db.Timestamptz
  in_progress_at DateTime?     @db.Timestamptz
  closed_at     DateTime?      @db.Timestamptz
  created_at    DateTime       @default(now()) @db.Timestamptz
  updated_at    DateTime       @updatedAt @db.Timestamptz

  building    Building         @relation(fields: [building_id], references: [id])
  floor       Floor            @relation(fields: [floor_id], references: [id])
  client      Client           @relation(fields: [client_id], references: [id])
  category    Category         @relation(fields: [category_id], references: [id])
  raiser      User             @relation(fields: [raised_by], references: [id])
  activities  TicketActivity[]
  attachments Attachment[]

  @@index([created_at(sort: Desc)])
  @@map("tickets")
}

model TicketActivity {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id     String       @db.Uuid
  actor_id      String       @db.Uuid
  activity_type ActivityType
  old_value     String?
  new_value     String?
  comment       String?
  is_internal   Boolean      @default(false)
  created_at    DateTime     @default(now()) @db.Timestamptz

  ticket Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actor_id], references: [id])

  @@map("ticket_activities")
}

model Attachment {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ticket_id   String   @db.Uuid
  uploaded_by String   @db.Uuid
  file_name   String?  @db.VarChar(255)
  file_url    String?
  file_size   Int?
  mime_type   String?  @db.VarChar(100)
  stage       String?  @db.VarChar(20)
  created_at  DateTime @default(now()) @db.Timestamptz

  ticket   Ticket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  uploader User   @relation(fields: [uploaded_by], references: [id])

  @@map("attachments")
}
